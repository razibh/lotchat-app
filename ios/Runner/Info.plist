    <key>BuildMachineOSBuild</key>
    <string>22F82</string>

    <!-- DT Platform Name -->
    <key>DTPlatformName</key>
    <string>iphoneos</string>

    <!-- DT SDK Name -->
    <key>DTSDKName</key>
    <string>iphoneos16.4</string>

    <!-- Minimum OS Version -->
    <key>MinimumOSVersion</key>
    <string>12.0</string>

    <!-- Supported Platforms -->
    <key>CFBundleSupportedPlatforms</key>
    <array>
        <string>iPhoneOS</string>
    </array>

    <!-- Device Capabilities -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer> <!-- iPhone -->
        <integer>2</integer> <!-- iPad -->
    </array>

    <!-- Exported URL Schemes -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.razib.lotchat</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>gamelive</string>
            </array>
        </dict>
    </array>
</dict>
</plist>


